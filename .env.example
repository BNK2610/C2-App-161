# ============================================
# V-VoiceRide — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ---- LLM Configuration ----
OPENAI_API_KEY=sk-your-key-here
# Or use other providers:
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ---- Database ----
DATABASE_URL=sqlite:///./data/voiceride.db
# For production:
# DATABASE_URL=postgresql://user:password@localhost:5432/voiceride
# Or Pinecone:
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=

# ---- App Config ----
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
DEFAULT_CITY=Ha Noi
MOCK_BOOKING_ENABLED=true
BOOKING_CONFIRMATION_REQUIRED=true
SUPPORTED_VEHICLE_TYPES=motorbike,car

# ---- LangSmith (AI Logs — Deliverable #4) ----
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=voiceride
LANGCHAIN_TRACING_V2=true

# ---- Logging ----
LOG_LEVEL=INFO

# ---- AI Hook Logging (provided by instructor) ----
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=f3p1dEOhD_z8qjjtbeCtb2t9ASMEliz-4juZfWe3ZPgCtPZp-LjWthBfeNU8d5dP
AI_LOG_DIR=.ai-log

# ---- Frontend (if separate) ----
# NEXT_PUBLIC_API_URL=http://localhost:8000
