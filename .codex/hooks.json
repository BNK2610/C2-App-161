{
  "version": "1.0",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "log-prompt",
            "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=codex",
            "commandWindows": "python scripts/log_hook.py --tool=codex",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "log-stop",
            "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=codex",
            "commandWindows": "python scripts/log_hook.py --tool=codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
